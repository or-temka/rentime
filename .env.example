# ==== Server settings ====
NEXT_SERVER_PORT = 3000
# HOST is optional; in production server.js defaults to 127.0.0.1 (not reachable from the internet).
# PORT/NEXT_SERVER_PORT — internal port for nginx proxy_pass (e.g. http://127.0.0.1:3000).

